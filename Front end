<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Anemilton Dev</title>
  <style>
    /* Reset básico */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    /* Fonte e cores principais */
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #f5f7fa;
      color: #333;
      line-height: 1.6;
      padding: 20px;
    }

    /* Cabeçalho */
    header {
      text-align: center;
      margin-bottom: 40px;
    }

    header h1 {
      font-size: 2.5rem;
      color: #2c3e50;
    }

    header p {
      font-size: 1.2rem;
      color: #555;
    }

    /* Seções */
    section {
      margin-bottom: 40px;
    }

    h2 {
      font-size: 1.8rem;
      color: #34495e;
      margin-bottom: 15px;
      border-bottom: 2px solid #3498db;
      display: inline-block;
      padding-bottom: 5px;
    }

    /* Lista de projetos */
    ul {
      list-style: none;
    }

    ul li {
      background: #fff;
      margin: 10px 0;
      padding: 15px;
      border-radius: 8px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

    ul li a {
      text-decoration: none;
      color: #3498db;
      font-weight: bold;
    }

    /* Contato */
    section p a {
      color: #3498db;
      text-decoration: none;
    }

    section p a:hover {
      text-decoration: underline;
    }

    /* Rodapé */
    footer {
      text-align: center;
      padding: 20px;
      background: #2c3e50;
      color: #fff;
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <header>
    <h1>Olá, eu sou Anemilton</h1>
    <p>Desenvolvedor em formação 🚀</p>
  </header>

  <section>
    <h2>Projetos</h2>
    <ul>
      <li><a href="#">API Node</a></li>
      <li><a href="#">Dashboard</a></li>
    </ul>
  </section>

  <section>
    <h2>Contato</h2>
    <p>Email: <a href="mailto:anemilton@example.com">anemilton@example.com</a></p>
    <p>GitHub: <a href="https://github.com/seuusuario" target="_blank">github.com/seuusuario</a></p>
    <p>LinkedIn: <a href="https://linkedin.com/in/seuusuario" target="_blank">linkedin.com/in/seuusuario</a></p>
  </section>

  <footer>
    <p>&copy; 2026 - Anemilton Dev</p>
  </footer>
</body>
</html>
